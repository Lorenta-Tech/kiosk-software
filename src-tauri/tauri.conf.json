{
  "$schema": "https://schema.tauri.app/config/2",

  "productName": "kiosk-engg",
  "version": "0.1.0",
  "identifier": "com.manojseetaramgowda.kiosk-engg",

  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1421",

    "beforeBuildCommand": "pnpm build",

    "frontendDist": "../dist"
  },

  "app": {
    "windows": [
      {
        "title": "kiosk-engg",

        "x": 0,
        "y": 0,

        "width": 1080,
        "height": 1920,

        "decorations": false,

        "resizable": false,

        "alwaysOnTop": true,

        "skipTaskbar": true,

        "visible": true,

        "focus": true,
        "devtools": true
      }
    ],

    "security": {
      "csp": null
    }
  },

  "bundle": {
    "active": true,

    "targets": "all",
    "resources": {
      "music/*": "music/"
    }
  }
}