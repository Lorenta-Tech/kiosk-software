{
  "$schema": "https://schema.tauri.app/config/2",

  "productName": "kiosk-engg",
  "version": "0.1.0",
  "identifier": "com.manojseetaramgowda.kiosk-engg",

  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },

  "app": {
    "windows": [
      {
        "title": "kiosk-engg",

        "width": 1080,
        "height": 1920,

        "minWidth": 1080,
        "minHeight": 1920,

        "maxWidth": 1080,
        "maxHeight": 1920,

        "fullscreen": true,
        "resizable": false,
        "decorations": false,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "visible": true,
        "focus": true,
        "center": true
      }
    ],

    "security": {
      "csp": null
    }
  },

  "bundle": {
    "active": true,
    "targets": "all",

    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}